                "exec": [
                  "const spec = pm.response.json();",
                  "const pathNames = Object.keys(spec.paths || {}).map(path => path.toLowerCase());",
                  "const operations = Object.values(spec.paths || {}).flatMap(path => ['get', 'post', 'put', 'patch', 'delete'].map(method => path[method]).filter(Boolean));",
                  "const requiredResources = ['students', 'courses', 'enrollments', 'subjects'];",
                  "pm.test('3-layer Architecture: runtime API proxy exposes a controller surface', function () {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(operations.length).to.be.greaterThan(10);",
                  "});",
                  "pm.test('Project Naming Convention: OpenAPI title uses PRN232 LMS API', function () {",
                  "  pm.expect(spec.info && spec.info.title).to.eql('PRN232 LMS API');",
                  "});",
                  "pm.test('4 Model Types: required resource models have API paths', function () {",
                  "  requiredResources.forEach(resource => pm.expect(pathNames.some(path => path.includes('/' + resource))).to.eql(true));",
                  "});",
                  "pm.test('RESTful Endpoint Naming: required resources use noun-based paths', function () {",
                  "  requiredResources.forEach(resource => pm.expect(pathNames.some(path => path.includes('/api/v1/' + resource))).to.eql(true));",
                  "});",
                  "pm.test('Swagger/OpenAPI: valid v1 document is available', function () {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(spec.openapi || spec.swagger).to.be.a('string');",
                  "  pm.expect(spec.paths).to.be.an('object');",
                  "});",
                  "pm.test('Code Quality: documented operations declare responses', function () {",
                  "  pm.expect(operations.length).to.be.greaterThan(10);",
                  "  pm.expect(operations.every(operation => operation.responses && Object.keys(operation.responses).length > 0)).to.eql(true);",
                  "});"
                ]
              }
            }
          ]
        }
