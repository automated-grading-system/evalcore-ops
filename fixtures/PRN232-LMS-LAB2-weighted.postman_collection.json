      "name": "Authentication",
      "item": [
        {
          "name": "Login admin success",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{adminUsername}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('admin login returns token pair without sensitive hashes', function () {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(json.success).to.eql(true);",
                  "  pm.expect(json.data.accessToken).to.be.a('string').and.not.empty;",
                  "  pm.expect(json.data.refreshToken).to.be.a('string').and.not.empty;",
                  "  pm.expect(json.data.expiresIn).to.be.a('number');",
                  "  pm.expect(json.data.username).to.eql('admin');",
                  "  pm.expect(json.data.role).to.eql('Admin');",
                  "  const bodyText = JSON.stringify(json).toLowerCase();",
                  "  pm.expect(bodyText).to.not.include('passwordhash');",
                  "  pm.expect(bodyText).to.not.include('refreshtokenhash');",
                  "  pm.expect(bodyText).to.not.include('tokenhash');",
                  "});",
                  "pm.collectionVariables.set('adminAccessToken', json.data.accessToken);",
                  "pm.collectionVariables.set('adminRefreshToken', json.data.refreshToken);"
                ]
              }
            }
          ]
        },
