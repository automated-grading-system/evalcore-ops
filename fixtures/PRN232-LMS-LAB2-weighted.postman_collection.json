          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const oldRefreshToken = pm.collectionVariables.get('adminRefreshToken');",
                  "const json = pm.response.json();",
                  "pm.test('refresh returns rotated token pair', function () {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(json.success).to.eql(true);",
                  "  pm.expect(json.data.accessToken).to.be.a('string').and.not.empty;",
                  "  pm.expect(json.data.refreshToken).to.be.a('string').and.not.empty;",
                  "  pm.expect(json.data.refreshToken).to.not.eql(oldRefreshToken);",
                  "});",
                  "pm.collectionVariables.set('newAdminAccessToken', json.data.accessToken);",
                  "pm.collectionVariables.set('newAdminRefreshToken', json.data.refreshToken);"
                ]
              }
            }
          ]
        },
        {
          "name": "Reuse old admin refresh token should fail",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
