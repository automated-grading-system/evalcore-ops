COMPOSE_PROJECT_NAME=ags

GATEWAY_PORT=8080
IDENTITY_UPSTREAM=host.docker.internal:8081

POSTGRES_DB=ags
POSTGRES_USER=ags
POSTGRES_PASSWORD=ags_password
POSTGRES_PORT=5432

RABBITMQ_DEFAULT_USER=ags
RABBITMQ_DEFAULT_PASS=ags_password
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_HOST=rabbitmq
