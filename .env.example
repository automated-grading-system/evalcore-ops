COMPOSE_PROJECT_NAME=ags

POSTGRES_DB=ags
POSTGRES_USER=ags
POSTGRES_PASSWORD=ags_password
POSTGRES_PORT=5432

RABBITMQ_DEFAULT_USER=ags
RABBITMQ_DEFAULT_PASS=ags_password
RABBITMQ_PORT=5672
RABBITMQ_PUBLISHED_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_HOST=rabbitmq
RABBITMQ_USERNAME=ags
RABBITMQ_PASSWORD=ags_password
RABBITMQ_EXCHANGE=ags.domain.events

MINIO_ROOT_USER=ags
MINIO_ROOT_PASSWORD=ags_password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_API_CORS_ALLOW_ORIGIN=http://localhost:3000,http://localhost:5173,https://prn232.dorriss.com

GATEWAY_PORT=8080

DOZZLE_IMAGE=amir20/dozzle:latest
DOZZLE_CONTAINER_NAME=ags-dozzle
DOZZLE_PUBLIC_PORT=9999

IDENTITY_IMAGE=dorrissdang/evalcore-identity-service:main
IDENTITY_CONTAINER_NAME=ags-identity-service
IDENTITY_PUBLIC_PORT=8081
IDENTITY_INTERNAL_PORT=8080
IDENTITY_UPSTREAM=identity-service:8080

IDENTITY_DATABASE_URL=Host=postgres;Port=5432;Database=ags;Username=ags;Password=ags_password

CLASS_IMAGE=dorrissdang/evalcore-class-service:main
CLASS_CONTAINER_NAME=ags-class-service
CLASS_PUBLIC_PORT=8082
CLASS_INTERNAL_PORT=8080
CLASS_UPSTREAM=class-service:8080
CLASS_DATABASE_URL=Host=postgres;Port=5432;Database=ags;Username=ags;Password=ags_password

SUBMISSION_IMAGE=dorrissdang/evalcore-submission-service:main
SUBMISSION_CONTAINER_NAME=ags-submission-service
SUBMISSION_PUBLIC_PORT=8083
SUBMISSION_INTERNAL_PORT=8080
SUBMISSION_UPSTREAM=submission-service:8080
SUBMISSION_DATABASE_URL=Host=postgres;Port=5432;Database=ags;Username=ags;Password=ags_password

EVALUATION_IMAGE=dorrissdang/evalcore-evaluation-service:main
EVALUATION_CONTAINER_NAME=ags-evaluation-service
EVALUATION_RUNNER_CONTAINER_NAME=ags-evaluation-runner
EVALUATION_PUBLIC_PORT=8084
EVALUATION_UPSTREAM=evaluation-service:8080
EVALUATION_DATABASE_URL=Host=postgres;Port=5432;Database=ags;Username=ags;Password=ags_password

GRADING_IMAGE=dorrissdang/evalcore-grading-service:main
GRADING_CONTAINER_NAME=ags-grading-service
GRADING_GRPC_PORT=5007
GRADING_HEALTH_PORT=8087
GRADING_UPSTREAM=grading-service:8080
GRADING_GRPC_URL=http://grading-service:5007
GRADING_GRPC_ENABLED=true

NOTIFICATION_IMAGE=dorrissdang/evalcore-notification-service:main
NOTIFICATION_CONTAINER_NAME=ags-notification-service
NOTIFICATION_PUBLIC_PORT=8086
NOTIFICATION_UPSTREAM=notification-service:8080
NOTIFICATION_DATABASE_URL=Host=postgres;Port=5432;Database=ags;Username=ags;Password=ags_password

ASPNETCORE_ENVIRONMENT=Development
JWT_SECRET=change-me-super-secret-local-dev-only-but-long-enough-123456
JWT_ISSUER=ags
JWT_AUDIENCE=ags-api
JWT_EXPIRES_MINUTES=1440
CORS_ALLOWED_ORIGINS=[http://localhost:3000,http://localhost:5173,https://prn232.dorriss.com]
AUTO_APPLY_MIGRATIONS=true

# Shared only by trusted backend services. Set the same value for Class Service
# and Evaluation Service; browser/user traffic cannot use this as JWT auth.
INTERNAL_SERVICE_TOKEN=dev-internal-service-token-change-me

S3_ENDPOINT=http://minio:9000
S3_INTERNAL_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=ags
S3_SECRET_KEY=ags_password
S3_USE_SSL=false
LAB_ASSETS_BUCKET=lab-assets
SUBMISSION_ASSETS_BUCKET=submission-assets
EVALUATION_REPORTS_BUCKET=evaluation-reports
PRESIGNED_URL_EXPIRES_MINUTES=15

CLASS_SERVICE_BASE_URL=http://class-service:8080
SUBMISSION_SERVICE_BASE_URL=http://submission-service:8080
IDENTITY_SERVICE_BASE_URL=http://identity-service:8080

SUBMISSION_SUBMITTED_ROUTING_KEY=submission.submitted.v1
EVALUATION_COMPLETED_ROUTING_KEY=evaluation.completed.v1
NOTIFICATION_EVALUATION_COMPLETED_ROUTING_KEY=evaluation.completed.v1

# Email delivery is disabled by default. Keep SMTP credentials in .env only.
NOTIFICATION_EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=EvalCore
SMTP_USE_STARTTLS=true
SMTP_USE_SSL=false
NOTIFICATION_EMAIL_SUBJECT_PREFIX=[EvalCore]

# Intentionally small: accepted bursts wait in RabbitMQ/the Evaluation DB
# instead of starting one untrusted Docker sandbox per submission.
EVALUATION_RUNNER_CONCURRENCY=2
EVALUATION_WORKDIR=/tmp/evalcore/evaluations
EVALUATION_APP_SERVICE_NAME=app
EVALUATION_APP_INTERNAL_PORT=8080
EVALUATION_APP_HEALTH_PATH=/health
EVALUATION_POSTMAN_BASE_URL_VARIABLE=baseUrl
EVALUATION_BUILD_TIMEOUT_SECONDS=180
# Demo-safe readiness window for fresh per-evaluation databases and cold hosts.
EVALUATION_STARTUP_TIMEOUT_SECONDS=180
EVALUATION_NEWMAN_TIMEOUT_SECONDS=120
EVALUATION_TOTAL_TIMEOUT_SECONDS=420
EVALUATION_CONTAINER_MEMORY_LIMIT=768m
EVALUATION_CONTAINER_CPUS=1.0
EVALUATION_CONTAINER_PIDS_LIMIT=256

# The burst demo refuses a non-loopback Gateway unless this is explicitly true;
# opted-in remote Gateways must use HTTPS.
# Leave the student password empty: local runs use a throwaway default and
# remote opt-in runs generate a strong per-run password without printing it.
DEMO_ALLOW_REMOTE=false
DEMO_FRONTEND_URL=http://localhost:3000
DEMO_STUDENT_PASSWORD=
DEMO_CURL_CONNECT_TIMEOUT_SECONDS=5
DEMO_CURL_HEALTH_TIMEOUT_SECONDS=10
DEMO_CURL_API_TIMEOUT_SECONDS=30
DEMO_CURL_UPLOAD_TIMEOUT_SECONDS=120

# ===============================
# On-prem / shared infrastructure overrides
# ===============================
# Copy the needed overrides into .env and replace every placeholder. These
# examples stay commented so the default file continues to run the local demo.

# The compose.onprem.yaml override joins app services to external selfhost_net.
# Shared containers on that network are reachable by their container names.

# External PostgreSQL: core_postgres
# IDENTITY_DATABASE_URL=Host=core_postgres;Port=5432;Database=ags;Username=<user>;Password=<password>
# CLASS_DATABASE_URL=Host=core_postgres;Port=5432;Database=ags;Username=<user>;Password=<password>
# SUBMISSION_DATABASE_URL=Host=core_postgres;Port=5432;Database=ags;Username=<user>;Password=<password>
# EVALUATION_DATABASE_URL=Host=core_postgres;Port=5432;Database=ags;Username=<user>;Password=<password>
# NOTIFICATION_DATABASE_URL=Host=core_postgres;Port=5432;Database=ags;Username=<user>;Password=<password>

# External RabbitMQ: judicator-rabbitmq
# RABBITMQ_HOST=judicator-rabbitmq
# RABBITMQ_PORT=5672
# RABBITMQ_USERNAME=<user>
# RABBITMQ_PASSWORD=<password>

# External S3 / MinIO
# S3_ENDPOINT=https://storage.dorriss.com
# S3_INTERNAL_ENDPOINT=https://storage.dorriss.com
# S3_PUBLIC_ENDPOINT=https://storage.dorriss.com
# S3_ACCESS_KEY=<access-key>
# S3_SECRET_KEY=<secret-key>
# S3_USE_SSL=true
# Alternative container-only internal endpoint: http://core_minio:9000

# Frontend / CORS
# CORS_ALLOWED_ORIGINS=[https://prn232.dorriss.com,http://localhost:3000,http://localhost:5173]
# MINIO_API_CORS_ALLOW_ORIGIN=https://prn232.dorriss.com,http://localhost:3000,http://localhost:5173

# Production secrets
# JWT_SECRET=<generate-with-openssl-rand-base64-48>
# INTERNAL_SERVICE_TOKEN=<generate-with-openssl-rand-base64-48>

# gRPC
# GRADING_GRPC_ENABLED=true
# GRADING_GRPC_URL=http://grading-service:5007

# Demo
# DEMO_FRONTEND_URL=https://prn232.dorriss.com
# DEMO_ALLOW_REMOTE=false

# Optional unused host ports when shared infra already occupies the defaults.
# RABBITMQ_PUBLISHED_PORT controls only the local container's host binding;
# RABBITMQ_PORT must remain the port used to reach the external broker.
# POSTGRES_PORT=15432
# RABBITMQ_PUBLISHED_PORT=15674
# RABBITMQ_MANAGEMENT_PORT=15675
# MINIO_API_PORT=19000
# MINIO_CONSOLE_PORT=19001

# S3_PUBLIC_ENDPOINT must be browser-reachable; never use localhost in a
# deployed environment. S3_INTERNAL_ENDPOINT must be reachable by containers.
# When both use the same public HTTPS MinIO endpoint, set S3_USE_SSL=true.
# External MinIO CORS must be configured on the real MinIO server, not only via
# MINIO_API_CORS_ALLOW_ORIGIN in this Compose stack.
# Never keep the default JWT_SECRET or INTERNAL_SERVICE_TOKEN in production.
