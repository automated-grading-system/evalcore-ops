:8080 {
	route {
		# The Gateway is the browser API boundary. Keep this explicit allow-list in
		# sync with CORS_ALLOWED_ORIGINS so upstream services do not need to handle
		# browser OPTIONS requests themselves.
		@api_origin_next {
			path /api/*
			header Origin http://localhost:3000
		}
		header @api_origin_next {
			>Access-Control-Allow-Origin "{http.request.header.Origin}"
			>Access-Control-Allow-Credentials true
			>Vary Origin
		}
		@api_origin_vite {
			path /api/*
			header Origin http://localhost:5173
		}
		header @api_origin_vite {
			>Access-Control-Allow-Origin "{http.request.header.Origin}"
			>Access-Control-Allow-Credentials true
			>Vary Origin
		}
		@api_origin_production {
			path /api/*
			header Origin https://prn232.dorriss.com
		}
		header @api_origin_production {
			>Access-Control-Allow-Origin "{http.request.header.Origin}"
			>Access-Control-Allow-Credentials true
			>Vary Origin
		}

		@api_preflight_next {
			method OPTIONS
			path /api/*
			header Origin http://localhost:3000
		}
		handle @api_preflight_next {
			header {
				Access-Control-Allow-Origin "{http.request.header.Origin}"
				Access-Control-Allow-Credentials true
				Access-Control-Allow-Headers "Authorization, Content-Type"
				Access-Control-Allow-Methods "GET, POST, PATCH, PUT, DELETE, OPTIONS"
				Access-Control-Max-Age 86400
				Vary "Origin, Access-Control-Request-Method, Access-Control-Request-Headers"
			}
			respond "" 204
		}
		@api_preflight_vite {
			method OPTIONS
			path /api/*
			header Origin http://localhost:5173
		}
		handle @api_preflight_vite {
			header {
				Access-Control-Allow-Origin "{http.request.header.Origin}"
				Access-Control-Allow-Credentials true
				Access-Control-Allow-Headers "Authorization, Content-Type"
				Access-Control-Allow-Methods "GET, POST, PATCH, PUT, DELETE, OPTIONS"
				Access-Control-Max-Age 86400
				Vary "Origin, Access-Control-Request-Method, Access-Control-Request-Headers"
			}
			respond "" 204
		}
		@api_preflight_production {
			method OPTIONS
			path /api/*
			header Origin https://prn232.dorriss.com
		}
		handle @api_preflight_production {
			header {
				Access-Control-Allow-Origin "{http.request.header.Origin}"
				Access-Control-Allow-Credentials true
				Access-Control-Allow-Headers "Authorization, Content-Type"
				Access-Control-Allow-Methods "GET, POST, PATCH, PUT, DELETE, OPTIONS"
				Access-Control-Max-Age 86400
				Vary "Origin, Access-Control-Request-Method, Access-Control-Request-Headers"
			}
			respond "" 204
		}

		# Gateway health is served directly by Caddy.
		handle /health {
			header Content-Type application/json
			respond `{"status":"healthy","service":"ags-gateway"}` 200
		}

		# Full Docker mode uses IDENTITY_UPSTREAM=identity-service:8080.
		# Legacy host mode can use IDENTITY_UPSTREAM=host.docker.internal:8081.

		# Debug route for checking the Identity Service through Caddy.
		handle /identity/health {
			rewrite * /health
			reverse_proxy http://{$IDENTITY_UPSTREAM}
		}

		# Debug route for checking the Class Service health through Caddy.
		handle /class/health {
			rewrite * /health
			reverse_proxy http://{$CLASS_UPSTREAM}
		}

		# Debug route for checking the Submission Service health through Caddy.
		handle /submission/health {
			rewrite * /health
			reverse_proxy http://{$SUBMISSION_UPSTREAM}
		}

		# Debug route for checking the Evaluation Service health through Caddy.
		handle /evaluation/health {
			rewrite * /health
			reverse_proxy http://{$EVALUATION_UPSTREAM}
		}

		# Health-only route for the internal Grading gRPC Service.
		handle /grading/health {
			rewrite * /health
			reverse_proxy http://{$GRADING_UPSTREAM}
		}

		# Identity internal routes deliberately have no public proxy route.
		handle /notification/health {
			rewrite * /health
			reverse_proxy http://{$NOTIFICATION_UPSTREAM}
		}

		# Single Swagger UI portal and same-origin OpenAPI documents. The gRPC
		# Grading Service is intentionally excluded because it is not a REST API.
		handle /docs/openapi/identity.json {
			rewrite * /swagger/v1/swagger.json
			reverse_proxy http://{$IDENTITY_UPSTREAM} {
				method GET
			}
		}

		handle /docs/openapi/class.json {
			rewrite * /swagger/v1/swagger.json
			reverse_proxy http://{$CLASS_UPSTREAM} {
				method GET
			}
		}

		handle /docs/openapi/submission.json {
			rewrite * /swagger/v1/swagger.json
			reverse_proxy http://{$SUBMISSION_UPSTREAM} {
				method GET
			}
		}

		handle /docs/openapi/evaluation.json {
			rewrite * /swagger/v1/swagger.json
			reverse_proxy http://{$EVALUATION_UPSTREAM} {
				method GET
			}
		}

		handle /docs/openapi/notification.json {
			rewrite * /swagger/v1/swagger.json
			reverse_proxy http://{$NOTIFICATION_UPSTREAM} {
				method GET
			}
		}

		handle /docs/swagger* {
			reverse_proxy http://swagger-ui:8080
		}

		# Identity API routes keep their /api prefixes when proxied upstream.
		handle /api/auth/* {
			reverse_proxy http://{$IDENTITY_UPSTREAM}
		}

		handle /api/users/* {
			reverse_proxy http://{$IDENTITY_UPSTREAM}
		}

		handle /api/admin/users* {
			reverse_proxy http://{$IDENTITY_UPSTREAM}
		}

		# Submission nested lab routes must come before generic /api/labs*.
		handle /api/labs/*/submissions/* {
			reverse_proxy http://{$SUBMISSION_UPSTREAM}
		}

		handle /api/labs/*/submissions* {
			reverse_proxy http://{$SUBMISSION_UPSTREAM}
		}

		# This outer route block preserves this order ahead of generic submissions.
		@submission_evaluations path_regexp submission_evaluations ^/api/submissions/[^/]+/evaluations(?:/.*)?$
		handle @submission_evaluations {
			reverse_proxy http://{$EVALUATION_UPSTREAM}
		}

		handle /api/evaluations* {
			reverse_proxy http://{$EVALUATION_UPSTREAM}
		}

		handle /api/notifications* {
			reverse_proxy http://{$NOTIFICATION_UPSTREAM}
		}

		handle /api/submissions* {
			reverse_proxy http://{$SUBMISSION_UPSTREAM}
		}

		# Class API routes keep their /api prefixes when proxied upstream.
		handle /api/classes* {
			reverse_proxy http://{$CLASS_UPSTREAM}
		}

		handle /api/labs* {
			reverse_proxy http://{$CLASS_UPSTREAM}
		}

		handle {
			header Content-Type application/json
			respond `{"error":"route_not_found"}` 404
		}
	}
}
